---
import { Image } from "astro:assets";

import MainHead from '../../components/MainHead.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { getTeamMember, getSocialUrls } from '../../scripts/team-members.js';
import badgeLinks from '../../data/badge-links.json';
import teamMemberPages from '../../data/team-members.js';

const images = import.meta.glob<{ default: ImageMetadata }>('../../images/teams/*-profile.jpg', { eager: true });

export function getStaticPaths() {
	return teamMemberPages.map((entry) => ({
		params: { slug: entry.slug },
		props: entry,
	}));
}

const {
	slug,
	memberKey,
	title,
	description,
	ogImageAlt,
	profileFirstName,
	profileLastName,
	jsonLdName,
	h1,
	imagePosition,
	bioHtml,
} = Astro.props;

const member = getTeamMember(memberKey);
const imagePath = `../../images/teams/${slug}-profile.jpg`;
const profileImage = images[imagePath].default;
const publicImagePath = `/images/teams/${slug}-profile.jpg`;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const sameAs = getSocialUrls(member);
const jsonLd = {
	"@context": "https://schema.org",
	"@type": "Person",
	"name": jsonLdName || member.name,
	"url": canonicalURL.toString(),
	"image": new URL(publicImagePath, Astro.site).toString(),
	"sameAs": sameAs,
};
---

<html lang="de">
	<head>
		<MainHead title={title} description={description} image={publicImagePath} {canonicalURL} ogType="profile" ogImageAlt={ogImageAlt} ogImageWidth={profileImage.width} ogImageHeight={profileImage.height} profileFirstName={profileFirstName} profileLastName={profileLastName} {jsonLd} />
	</head>

	<body class="antialiased bg-body text-body font-body">
		<div>
			<Nav title={title} />

			<section class="py-24 md:py-32 bg-white overflow-hidden" style="background-image: url('/images/elements/pattern-white.svg'); background-position: center;">
				<div class="container px-4 mx-auto">
					<div class="flex flex-wrap lg:items-start -mx-4">
						{imagePosition === "left" ? (
							<>
								<div class="w-full md:w-1/2 px-4 mb-16 md:mb-0">
									<div class="relative mx-auto md:ml-0 max-w-max">
										<img class="absolute z-10 -left-8 -top-8 w-28 md:w-auto text-yellow-400" src="/images/elements/circle3-red.svg" alt="Roter Kreis" />
										<img class="absolute z-10 -right-7 -bottom-8 w-28 md:w-auto text-blue-500" src="/images/elements/dots3-green.svg" alt="Grüne Punkte" />
										<Image class="rounded-2xl" src={profileImage} alt={ogImageAlt} title={ogImageAlt} />
									</div>
								</div>
								<div class="w-full md:w-1/2 px-4">
									<div class="flex flex-wrap items-center gap-2 mb-4">
										{member.subtitle && (
											<span class="inline-block py-px px-2 text-xs leading-5 text-yellow-500 bg-yellow-100 font-medium uppercase rounded-full shadow-sm">{member.subtitle}</span>
										)}
										{member.badges && member.badges.map((badge) => (
											<a href={badgeLinks[badge] || '#'} class="inline-block py-px px-2 text-xs leading-5 text-yellow-500 bg-yellow-100 font-medium uppercase rounded-full shadow-sm hover:bg-yellow-200 transition-colors">{badge}</a>
										))}
									</div>
									<div class="flex items-center mb-4">
										{member.social.github && (
											<a class="inline-block mr-6 hover:opacity-80" href={`https://github.com/${member.social.github}`}>
												<img src="/images/brands/github-gray.svg" alt={`${member.name} auf GitHub`} />
											</a>
										)}
										{member.social.x && (
											<a class="inline-block mr-6 hover:opacity-80" href={`https://x.com/${member.social.x}`}>
												<img src="/images/brands/x.svg" alt={`${member.name} auf X`} />
											</a>
										)}
										{member.social.bluesky && (
											<a class="inline-block mr-6 hover:opacity-80" href={member.social.bluesky}>
												<img src="/images/brands/bluesky-gray.svg" alt={`${member.name} auf Bluesky`} />
											</a>
										)}
										{member.social.mastodon && (
											<a class="inline-block mr-6 hover:opacity-80" href={member.social.mastodon}>
												<img src="/images/brands/mastodon-gray.svg" alt={`${member.name} auf Mastodon`} />
											</a>
										)}
										{member.social.linkedin && (
											<a class="inline-block mr-6 hover:opacity-80" href={`https://linkedin.com/in/${member.social.linkedin}`}>
												<img src="/images/brands/linkedin.svg" alt={`${member.name} auf LinkedIn`} />
											</a>
										)}
										{member.social.website && (
											<a class="inline-block hover:opacity-80" href={member.social.website}>
												<img src="/images/elements/icon-website.svg" height="33" width="33" alt={`Website von ${member.name}`} />
											</a>
										)}
									</div>
									<h1 class="mb-6 text-4xl md:text-5xl leading-tight text-coolGray-900 font-bold tracking-tight" set:html={h1} />
									<Fragment set:html={bioHtml} />
								</div>
							</>
						) : (
							<>
								<div class="w-full md:w-1/2 px-4 mb-16 md:mb-0">
									<div class="flex flex-wrap items-center gap-2 mb-4">
										{member.subtitle && (
											<span class="inline-block py-px px-2 text-xs leading-5 text-yellow-500 bg-yellow-100 font-medium uppercase rounded-full shadow-sm">{member.subtitle}</span>
										)}
										{member.badges && member.badges.map((badge) => (
											<a href={badgeLinks[badge] || '#'} class="inline-block py-px px-2 text-xs leading-5 text-yellow-500 bg-yellow-100 font-medium uppercase rounded-full shadow-sm hover:bg-yellow-200 transition-colors">{badge}</a>
										))}
									</div>
									<div class="flex items-center mb-4">
										{member.social.github && (
											<a class="inline-block mr-6 hover:opacity-80" href={`https://github.com/${member.social.github}`}>
												<img src="/images/brands/github-gray.svg" alt={`${member.name} auf GitHub`} />
											</a>
										)}
										{member.social.x && (
											<a class="inline-block mr-6 hover:opacity-80" href={`https://x.com/${member.social.x}`}>
												<img src="/images/brands/x.svg" alt={`${member.name} auf X`} />
											</a>
										)}
										{member.social.bluesky && (
											<a class="inline-block mr-6 hover:opacity-80" href={member.social.bluesky}>
												<img src="/images/brands/bluesky-gray.svg" alt={`${member.name} auf Bluesky`} />
											</a>
										)}
										{member.social.mastodon && (
											<a class="inline-block mr-6 hover:opacity-80" href={member.social.mastodon}>
												<img src="/images/brands/mastodon-gray.svg" alt={`${member.name} auf Mastodon`} />
											</a>
										)}
										{member.social.linkedin && (
											<a class="inline-block mr-6 hover:opacity-80" href={`https://linkedin.com/in/${member.social.linkedin}`}>
												<img src="/images/brands/linkedin.svg" alt={`${member.name} auf LinkedIn`} />
											</a>
										)}
										{member.social.website && (
											<a class="inline-block hover:opacity-80" href={member.social.website}>
												<img src="/images/elements/icon-website.svg" height="33" width="33" alt={`Website von ${member.name}`} />
											</a>
										)}
									</div>
									<h1 class="mb-6 text-4xl md:text-5xl leading-tight text-coolGray-900 font-bold tracking-tight" set:html={h1} />
									<Fragment set:html={bioHtml} />
								</div>
								<div class="w-full md:w-1/2 px-4">
									<div class="relative mx-auto md:mr-0 max-w-max">
										<img class="absolute z-10 -left-8 -top-8 w-28 md:w-auto text-yellow-400" src="/images/elements/circle3-red.svg" alt="Roter Kreis" />
										<img class="absolute z-10 -right-7 -bottom-8 w-28 md:w-auto text-blue-500" src="/images/elements/dots3-green.svg" alt="Grüne Punkte" />
										<Image class="rounded-2xl" src={profileImage} alt={ogImageAlt} title={ogImageAlt} />
									</div>
								</div>
							</>
						)}
					</div>
				</div>
			</section>

			<Footer />
		</div>
	</body>
</html>
