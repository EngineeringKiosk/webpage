---
import MeetupArchiveLayout from '../../../../components/meetup/MeetupArchiveLayout.astro';

const alpsImage = (await import('../../../../images/meetup-alps/slider/ibk.jpg')).default;
---

<MeetupArchiveLayout
	collectionName="meetup-alps"
	meetupName="Alps"
	pageTitle="Talks Archive - Engineering Kiosk Alps Meetup Innsbruck"
	pageDescription="Browse all past talks from the Engineering Kiosk Alps meetup in Innsbruck. A local community event for software engineers featuring talks on engineering culture, open source and technology."
	ogImage="/meetup/alps/images/ibk.jpg"
	badgeText="Tech Meetup Innsbruck"
	archiveTitle="Engineering Kiosk Alps<br />Meetup Innsbruck<br />Talks Archive"
	heroImage={alpsImage}
	heroImageAlt="View on Innsbruck"
	heroImageTitle="View on Innsbruck"
	showNewsletterForm={true}
	teamBadge="The local team in Innsbruck"
	teamTitle="Team Engineering Kiosk Alps"
	teamDescription="The organizers of Engineering Kiosk Alps Innsbruck."
	teamEmail="alps@engineeringkiosk.dev"
	teamMembers={[
		{ memberKey: "wolfgang-gassler" },
		{ memberKey: "tim-hannemann" },
		{ memberKey: "romedius-weiss" },
		{ memberKey: "christoph-stanger" },
		{ memberKey: "mirjam-ziselsberger" },
	]}
/>
