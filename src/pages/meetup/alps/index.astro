---
import MeetupPageLayout from '../../../components/meetup/MeetupPageLayout.astro';

// Dynamically import all images from the slider directory
const imageModules = import.meta.glob('../../../images/meetup-alps/slider/*.{jpg,jpeg,png,webp,avif}', { eager: true });
const sliderImages = Object.entries(imageModules).map(([path, module]) => ({
  src: (module as any).default,
  alt: "",
  title: ""
}));

---

<MeetupPageLayout
	collectionName="meetup-alps"
	meetupName="Alps"
	pageTitle="Meetup Alps - Engineering Kiosk - Innsbruck"
	ogImage="/meetup/alps/images/ibk.jpg"
	badgeText="Tech Meetup Innsbruck"
	heroTitle="Engineering Kiosk Alps<br />Meetup Innsbruck"
	heroDescription="Join us at Engineering Kiosk Alps, a dynamic tech meetup happening in the heart of the Alps, in Innsbruck! This event brings together tech enthusiasts, engineers, and professionals from various fields to explore the intersection of engineering culture, open source, people and technology."
	sliderImages={sliderImages}
	showRegistrationForm={true}
	showGeneralLanguageNote={true}
	showNewsletterForm={true}
	regionDescription="tech people in Tyrol"
	teamBadge="The local team in Innsbruck"
	teamTitle="Team Engineering Kiosk Alps"
	teamDescription="The organizers of Engineering Kiosk Alps Innsbruck."
	teamEmail="alps@engineeringkiosk.dev"
	teamMembers={[
		{ memberKey: "wolfgang-gassler" },
		{ memberKey: "tim-hannemann" },
		{ memberKey: "romedius-weiss" },
		{ memberKey: "christoph-stanger" },
		{ memberKey: "mirjam-ziselsberger" },
	]}
/>
