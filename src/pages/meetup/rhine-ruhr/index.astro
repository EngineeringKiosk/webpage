---
import MeetupPageLayout from '../../../components/meetup/MeetupPageLayout.astro';

// Dynamically import all images from the slider directory
const imageModules = import.meta.glob('../../../images/meetup-rhine-ruhr/slider/*.{jpg,jpeg,png,webp,avif}', { eager: true });

// Prepare images array for the slider by processing the dynamic imports
const sliderImages = await Promise.all(
  Object.entries(imageModules).map(async ([path, module]) => ({
    src: (module as any).default,
    alt: "",
    title: ""
  }))
);

---

<MeetupPageLayout
	collectionName="meetup-rhine-ruhr"
	title="Meetup Rhine-Ruhr - Engineering Kiosk - Germany"
	description="Tech Meetup in Rhine-Ruhr (Next: ${dateString}): Brings together tech enthusiasts, engineers, developers, and professionals from various fields to explore the intersection of engineering culture, open source, people and technology."
	ogImage="/meetup/rhine-ruhr/images/rr.jpg"
	badgeText="Tech Meetup Rhine-Ruhr"
	heroTitle="Engineering Kiosk Rhine-Ruhr Meetup Germany"
	heroDescription="Join us at Engineering Kiosk Rhine-Ruhr, a dynamic tech meetup happening in the heart of the Rhine-Ruhr region, in Germany! This event brings together tech enthusiasts, engineers, and professionals from various fields to explore the intersection of engineering culture, open source, people and technology."
	sliderImages={sliderImages}
	meetupName="Rhine-Ruhr"
	showGeneralLanguageNote={false}
	showRegistrationForm={false}
	showNewsletterForm={false}
	discordMeetupName="Rhine-Ruhr"
	regionDescription="tech people in the Rhine-Ruhr region"
	teamBadge="The local team of Rhine-Ruhr"
	teamTitle="Team Engineering Kiosk Rhine-Ruhr"
	teamDescription="The organizers of Engineering Kiosk Rhine-Ruhr."
	teamEmail="rhine-ruhr@engineeringkiosk.dev"
	teamMembers={[
		{ memberKey: "andy-grunwald" },
		{ memberKey: "schepp" },
		{ memberKey: "dario-tilgner" },
	]}
/>
