---
import MeetupArchiveLayout from '../../../../components/meetup/MeetupArchiveLayout.astro';

const rhineRuhrImage = (await import('../../../../images/meetup-rhine-ruhr/slider/duesseldorf-skyline.jpg')).default;
---

<MeetupArchiveLayout
	collectionName="meetup-rhine-ruhr"
	meetupName="Rhine-Ruhr"
	pageTitle="Archive of Engineering Kiosk Rhine-Ruhr Meetup in Germany"
	pageDescription="Tech Meetup in the Rhine-Ruhr region, brings together tech enthusiasts, engineers, and professionals from various fields to explore the intersection of engineering culture, open source, people and technology."
	ogImage="/meetup/rhine-ruhr/images/rr.jpg"
	badgeText="Tech Meetup Rhine-Ruhr"
	archiveTitle="Engineering Kiosk Rhine-Ruhr<br />Meetup Germany<br />Talks Archive"
	heroImage={rhineRuhrImage}
	heroImageAlt="Düsseldorf Skyline"
	heroImageTitle="Düsseldorf Skyline"
	showNewsletterForm={false}
	teamBadge="The local team of Rhine-Ruhr"
	teamTitle="Team Engineering Kiosk Rhine-Ruhr"
	teamDescription="The organizers of Engineering Kiosk Rhine-Ruhr."
	teamEmail="rhine-ruhr@engineeringkiosk.dev"
	teamMembers={[
		{ memberKey: "andy-grunwald" },
		{ memberKey: "schepp" },
		{ memberKey: "dario-tilgner" },
	]}
/>
