---
// Meetup newsletter signup backed by the Engineering Kiosk newsletter
// worker (https://api.engineeringkiosk.dev/newsletter/subscribe). Mirrors
// the section layout of ./Newsletter.astro (legacy RSVP backend used by
// the Alps meetup) so meetup pages look consistent regardless of backend.
//
// The form always subscribes to `primaryNewsletter` and, when the
// (default-checked) secondary checkbox is on, additionally subscribes to
// `secondaryNewsletter` — used to opt people into the general Engineering
// Kiosk newsletter alongside the meetup list.

import { formatDateWithoutWeekday } from '../../scripts/date.js';
import { createMeetupHelpers } from '../../scripts/meetups.js';

export interface Props {
	collectionName: string;
	meetupDisplayName: string;
	showForm?: boolean;
	source: string;
	primaryNewsletter: string;
	secondaryNewsletter?: string;
	secondaryNewsletterLabel?: string;
}

const {
	collectionName,
	meetupDisplayName,
	showForm = false,
	source,
	primaryNewsletter,
	secondaryNewsletter = 'general',
	secondaryNewsletterLabel = 'Also subscribe to the general Engineering Kiosk newsletter (in German)',
} = Astro.props;

const { getNextMeetups } = await createMeetupHelpers(collectionName);
const dates = getNextMeetups().map((meetup) => meetup.date);

const NEWSLETTER_ENDPOINT = 'https://api.engineeringkiosk.dev/newsletter/subscribe';

const idSuffix = Math.random().toString(36).slice(2, 10);
const formElementId = `meetup-newsletter-form-${idSuffix}`;
const inputId = `meetup-newsletter-email-${idSuffix}`;
const statusId = `meetup-newsletter-status-${idSuffix}`;
const honeypotId = `meetup-newsletter-company-${idSuffix}`;
const checkboxId = `meetup-newsletter-also-${idSuffix}`;
const configId = `${formElementId}-config`;

const messages = {
	loading: 'Subscribing...',
	success: 'Thanks! Please check your inbox to confirm your subscription.',
	generic: 'Something went wrong. Please try again later or contact us via email.',
	invalidEmail: 'Please enter a valid email address.',
};

const config = {
	formElementId,
	inputId,
	statusId,
	honeypotId,
	checkboxId,
	endpoint: NEWSLETTER_ENDPOINT,
	source,
	primaryNewsletter,
	secondaryNewsletter,
	messages,
};
---
<section class="py-4 md:py-24 bg-coolGray-50" style="background-image: url('/images/elements/pattern-light-big.svg'); background-position: center;">
	<a name="newsletter"></a>
	<div class="container px-4 mx-auto w-full md:w-1/2">
		<div class="mb-16 text-center">
			<h3 class="mb-4 text-3xl md:text-5xl leading-tight text-coolGray-900 font-bold tracking-tight">Interested in upcoming meetups?</h3>
			{showForm && (
				<p class="text-lg md:text-xl text-coolGray-500 font-medium">
					Register to our Engineering Kiosk {meetupDisplayName} newsletter (in English) and receive emails about upcoming meetups.<br />
					No worries, we won't spam you and you can unsubscribe at any time.
				</p>

				<form id={formElementId} novalidate class="w-full" aria-describedby={statusId} data-newsletter-worker-form data-config-id={configId}>
					<label for={inputId} class="sr-only">Your email address</label>
					<div class="flex flex-col sm:flex-row gap-3 max-w-xl mx-auto">
						<input
							id={inputId}
							class="flex-1 bg-white px-3 h-12 text-coolGray-900 outline-none placeholder-coolGray-500 border border-coolGray-200 focus:ring-2 focus:ring-yellow-500 focus:ring-opacity-50 rounded-lg shadow-xs"
							name="email"
							type="email"
							required
							autocomplete="email"
							placeholder="Your email address"
						/>
						<input id={honeypotId} type="text" name="company" tabindex="-1" autocomplete="off" aria-hidden="true" class="absolute left-[-9999px] h-0 w-0 opacity-0" />
						<button type="submit" class="py-4 px-5 leading-4 cursor-pointer text-yellow-50 font-medium text-center bg-yellow-500 hover:bg-yellow-600 focus:ring-2 focus:ring-yellow-500 focus:ring-opacity-50 rounded-md shadow-sm disabled:opacity-60 disabled:cursor-not-allowed">Subscribe</button>
					</div>
					<div class="max-w-xl mx-auto mt-3 flex justify-center">
						<label for={checkboxId} class="inline-flex items-center text-base text-coolGray-500 font-medium cursor-pointer">
							<input id={checkboxId} type="checkbox" checked class="mr-2" />
							{secondaryNewsletterLabel}
						</label>
					</div>
					<p id={statusId} role="status" aria-live="polite" tabindex="-1" class="hidden mt-4 text-lg md:text-xl text-coolGray-500 font-medium"></p>
				</form>

				<script id={configId} type="application/json" is:inline set:html={JSON.stringify(config).replace(/</g, '\\u003c')} />
			)}
		</div>
	</div>
	<div class="container px-4 mx-auto w-full md:w-1/2">
		<div class="mb-16 text-center">
			<h4 class="mb-4 text-xl md:text-xl leading-tight text-coolGray-900 font-bold tracking-tight">Upcoming tentative meetups:</h4>
			<p class="text-lg md:text-xl text-coolGray-500 font-medium">
				{dates.map((date) =>
					<b>{formatDateWithoutWeekday(date, 'en-US')}</b><br/>
				)}
			{showForm && (
				<br/>
				<Fragment>Please register to the Newsletter to get notified when the talk dates get fixed, as those are preliminary.</Fragment>
			)}
			</p>
		</div>
	</div>
</section>

<script>
	import { isValidEmail, buildNewsletterPayload, interpretNewsletterResponse } from '../../scripts/newsletter.js';

	function initNewsletterWorkerForm(form) {
		const configId = form.dataset.configId;
		const configEl = document.getElementById(configId);
		if (!configEl) {
			return;
		}
		const config = JSON.parse(configEl.textContent);
		const { inputId, statusId, honeypotId, checkboxId, endpoint, source, primaryNewsletter, secondaryNewsletter, messages } = config;

		const input = document.getElementById(inputId);
		const status = document.getElementById(statusId);
		const honeypot = document.getElementById(honeypotId);
		const checkbox = document.getElementById(checkboxId);
		const button = form.querySelector('button[type="submit"]');

		const showMessage = (text) => {
			status.textContent = text;
			status.classList.remove('hidden');
		};

		const setLoading = (loading) => {
			button.disabled = loading;
			input.disabled = loading;
			if (checkbox) {
				checkbox.disabled = loading;
			}
		};

		const handleSuccess = () => {
			form.reset();
			showMessage(messages.success);
			setLoading(false);
			input.disabled = true;
			button.disabled = true;
			if (checkbox) {
				checkbox.disabled = true;
			}
			status.focus({ preventScroll: false });
		};

		const handleError = (text) => {
			showMessage(text);
			setLoading(false);
			input.focus();
		};

		form.addEventListener('submit', async (event) => {
			event.preventDefault();

			if (honeypot.value.trim() !== '') {
				handleSuccess();
				return;
			}

			if (!input.checkValidity() || !isValidEmail(input.value)) {
				handleError(messages.invalidEmail);
				return;
			}

			setLoading(true);
			showMessage(messages.loading);

			const newsletters = [primaryNewsletter];
			if (checkbox && checkbox.checked && secondaryNewsletter) {
				newsletters.push(secondaryNewsletter);
			}

			let response;
			try {
				response = await fetch(endpoint, {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify(
						buildNewsletterPayload({
							email: input.value.trim(),
							newsletters,
							source,
							honeypot: honeypot.value,
						}),
					),
				});
			} catch (_networkError) {
				handleError(messages.generic);
				return;
			}

			const verdict = interpretNewsletterResponse({ status: response.status, messages });
			if (verdict.kind === 'success') {
				handleSuccess();
			} else {
				if (verdict.kind === 'server') {
					console.error('Meetup newsletter signup failed', { status: response.status });
				}
				handleError(verdict.message);
			}
		});
	}

	const wireUpForms = () => {
		document.querySelectorAll('form[data-newsletter-worker-form]').forEach((form) => initNewsletterWorkerForm(form));
	};

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', wireUpForms);
	} else {
		wireUpForms();
	}
</script>
