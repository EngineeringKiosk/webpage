---
import Footer from '../Footer.astro';
import MainHead from '../MainHead.astro';
import MeetupListing from './MeetupListing.astro';
import Nav from '../Nav.astro';
import Discord from './Discord.astro';
import Newsletter from './Newsletter.astro';
import MeetupArchiveEvent from './MeetupArchiveEvent.astro';
import Team from './Team.astro';
import { Image } from "astro:assets";

import { createMeetupHelpers } from '../../scripts/meetups';

export interface Props {
	collectionName: string;
	meetupName: string;
	pageTitle: string;
	pageDescription: string;
	ogImage: string;
	badgeText: string;
	archiveTitle: string;
	heroImage: any;
	heroImageAlt: string;
	heroImageTitle: string;
	teamBadge: string;
	teamTitle: string;
	teamDescription: string;
	teamEmail: string;
	teamMembers: Array<{ memberKey: string }>;
	showNewsletterForm?: boolean;
}

const {
	collectionName,
	meetupName,
	pageTitle,
	pageDescription,
	ogImage,
	badgeText,
	archiveTitle,
	heroImage,
	heroImageAlt,
	heroImageTitle,
	teamBadge,
	teamTitle,
	teamDescription,
	teamEmail,
	teamMembers,
	showNewsletterForm = false,
} = Astro.props;

const meetupSlug = collectionName.replace('meetup-', '');
const { getPastMeetups } = await createMeetupHelpers(collectionName);
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const meetupArchive = getPastMeetups();

---

<html lang="de">
	<head>
		<MainHead title={pageTitle} description={pageDescription} image={ogImage} {canonicalURL} />
	</head>

	<body class="antialiased bg-body text-body font-body">
		<div>
			<Nav title={pageTitle} />

			<section class="relative bg-white overflow-hidden" style="background-image: url('/images/elements/pattern-white.svg'); background-position: center;">
				<div class="py-20 md:py-28">
					<div class="container px-4 mx-auto">
						<div class="flex flex-wrap xl:items-center -mx-4">
							<div class="w-full md:w-1/2 px-4 mb-16 md:mb-0">
								<h1>
									<div>
										<span class="inline-block w-auto py-px px-2 mb-4 text-xs leading-5 text-white bg-yellow-500 uppercase rounded-9xl">{badgeText}</span>
									</div>
									<span class="block mb-6 text-3xl md:text-5xl lg:text-5xl 2xl:text-6xl leading-tight font-bold tracking-tight" set:html={archiveTitle} />
								</h1>
							</div>

							<div class="w-full md:w-1/2 px-4">
								<div class="relative mx-auto md:mr-0 max-w-max">
									<img class="absolute z-10 -left-14 -top-12 w-28 md:w-auto" src="/images/elements/circle3-red.svg" alt="Roter Kreis" />
									<img class="absolute z-10 -right-7 -bottom-8 w-28 md:w-auto" src="/images/elements/dots3-green.svg" alt="Grüne Punkte" />
									<Image class="relative rounded-7xl h-80 w-80" src={heroImage} alt={heroImageAlt} title={heroImageTitle} />
								</div>
							</div>
						</div>
					</div>
				</div>
			</section>
		</div>

		<section class="py-12 bg-white">
			<div class="container px-4 mx-auto">
				<div class="mb-8 text-center">
					<span class="inline-block py-px px-2 mb-4 text-xs leading-5 text-yellow-500 bg-yellow-100 font-medium uppercase rounded-9xl">Meetup Overview</span>
					<h2 class="mb-4 text-3xl md:text-4xl leading-tight text-coolGray-900 font-bold tracking-tight">Past Meetups at a Glance</h2>
					<p class="mb-10 text-lg md:text-xl text-coolGray-500 font-medium">A quick overview of our past meetups.</p>
				</div>

				<div class="flex flex-col space-y-6 mb-16">

					<!-- Meetup Rows -->
					{meetupArchive.map((meetup) => (
						<MeetupArchiveEvent meetup={meetup} meetupSlug={meetupSlug} />
					))}
				</div>
			</div>
		</section>

		<style>
			@media (max-width: 768px) {
				.flex-col.md\:flex-row > div:not(:last-child) {
					border-bottom: 1px solid #e5e7eb;
				}
			}
		</style>

    <MeetupListing headline='Meetup Tech Talk Archive' archive={true} meetupsToShow={meetupArchive} meetupName={meetupName} meetupSlug={meetupSlug} meetupImage={ogImage} />

		<Newsletter collectionName={collectionName} meetupDisplayName={meetupName} showForm={showNewsletterForm} />
		<Discord meetupName={meetupName} />
		<Team
			badge={teamBadge}
			title={teamTitle}
			description={teamDescription}
			email={teamEmail}
			members={teamMembers}
		/>
		<Footer />

	</body>
</html>
