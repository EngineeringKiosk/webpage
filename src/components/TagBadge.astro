---
export interface Props {
	name: string;
	url?: string;
}

const { name, url } = Astro.props;
---

{url ? (
	<a href={url} class="inline-block py-px px-2 mb-1 mr-1 text-xs leading-5 text-yellow-500 hover:text-yellow-600 font-medium uppercase bg-yellow-100 hover:bg-yellow-200 rounded-full shadow-sm">
		{name}
	</a>
) : (
	<span class="inline-block py-px px-2 mb-1 mr-1 text-xs leading-5 text-yellow-500 font-medium uppercase bg-yellow-100 rounded-full shadow-sm">
		{name}
	</span>
)}
