---
export interface Props {
	episode: number;
}

import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import { cutText } from '../scripts/strings.js';
import TagBadge from '../components/TagBadge.astro';

const { episode } = Astro.props;

let episodeString = episode.toString();

const episodes = await getCollection("podcast", ({ id }) => {
  return id.startsWith(`${episodeString}-`);
});
const content = episodes[0];
const data = content.data;

const description = cutText(data.description, 200);
---

<div class="container px-4 mx-auto my-10">
	<div class="flex flex-wrap lg:items-center -mx-4">
		<div class="w-full md:w-1/3">
			<div class="relative mx-auto md:ml-0 max-w-max">
				<a class="block mb-6 overflow-hidden" href={`/podcast/episode/${content.id}/`}>
					<Image class="rounded-2xl" src={data.image} title={`Podcast episode ${data.title}`} alt={`Podcast episode ${data.title}`} loading="lazy" decoding="async" format="webp" quality={80} />
				</a>
			</div>
		</div>
		<div class="w-full md:w-2/3 px-4">
			<TagBadge name="Mehr zu diesem Thema in unserer Podcast Episode" />

			<h4 class="">
				<a class="inline-block mb-4 text-2xl leading-tight text-coolGray-800 hover:text-coolGray-900 hover:underline" href={`/podcast/episode/${content.id}/`}>
					{data.title}
				</a>
			</h4>
			<p class="">
				{description}
			</p>
		</div>
	</div>
</div>
